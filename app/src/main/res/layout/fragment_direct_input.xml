<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.directinput.DirectInputFragment">

    <LinearLayout
        android:id="@+id/amountDisplayLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/intDigit1"
            style="@style/AmountDigitStyle"
            android:text="_" />

        <TextView
            android:id="@+id/intDigit2"
            style="@style/AmountDigitStyle"
            android:text="_" />

        <TextView
            android:id="@+id/intDigit3"
            style="@style/AmountDigitStyle"
            android:text="_" />

        <TextView
            android:id="@+id/decimalPoint"
            style="@style/AmountDigitStyle"
            android:text="." />

        <TextView
            android:id="@+id/decDigit1"
            style="@style/AmountDigitStyle"
            android:text="_" />

        <TextView
            android:id="@+id/decDigit2"
            style="@style/AmountDigitStyle"
            android:text="_" />
    </LinearLayout>

    <GridLayout
        android:id="@+id/keypadLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:columnCount="3"
        android:rowCount="4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/amountDisplayLayout">

        <Button
            android:id="@+id/btn7"
            android:text="7" />

        <Button
            android:id="@+id/btn8"
            android:text="8" />

        <Button
            android:id="@+id/btn9"
            android:text="9" />

        <Button
            android:id="@+id/btn4"
            android:text="4" />

        <Button
            android:id="@+id/btn5"
            android:text="5" />

        <Button
            android:id="@+id/btn6"
            android:text="6" />

        <Button
            android:id="@+id/btn1"
            android:text="1" />

        <Button
            android:id="@+id/btn2"
            android:text="2" />

        <Button
            android:id="@+id/btn3"
            android:text="3" />

        <Button
            android:id="@+id/btnDelete"
            android:text="DEL" />

        <Button
            android:id="@+id/btn0"
            android:text="0" />

        <Button
            android:id="@+id/btnEnter"
            android:enabled="false"
            android:text="ENTER" />
    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
