<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    tools:context=".ui.calculator.CalculatorFragment">

    <!-- Cash Register Display Area -->
    <LinearLayout
        android:id="@+id/displayContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/white"
        android:elevation="4dp"
        android:gravity="bottom|end"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.25"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/textActiveOperation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:textColor="@color/textColorSecondary"
            android:textSize="20sp"
            android:visibility="gone"
            tools:text="3 x 2"
            tools:visibility="visible" />

        <TextView
            android:id="@+id/currentInput"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:includeFontPadding="false"
            android:text="0.00"
            android:textColor="@color/textColorPrimary"
            android:textSize="64sp"
            android:textStyle="bold"
            tools:text="123.45" />

    </LinearLayout>

    <!-- Keypad using GridLayout -->
    <GridLayout
        android:id="@+id/keypadLayout"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:columnCount="4"
        android:rowCount="5"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/displayContainer">

        <!-- Row 1 -->
        <Button android:id="@+id/btnClear" style="@style/CalculatorButton" android:text="C" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btnMultiply" style="@style/CalculatorButton.Operator" android:text="x" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btnDivide" style="@style/CalculatorButton.Operator" android:text="/" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btnPercent" style="@style/CalculatorButton.Operator" android:text="%" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>

        <!-- Row 2 -->
        <Button android:id="@+id/btn7" style="@style/CalculatorButton.Number" android:text="7" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btn8" style="@style/CalculatorButton.Number" android:text="8" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btn9" style="@style/CalculatorButton.Number" android:text="9" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btnSubtract" style="@style/CalculatorButton.Operator" android:text="-" 
            android:backgroundTint="@color/errorColor"
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>

        <!-- Row 3 -->
        <Button android:id="@+id/btn4" style="@style/CalculatorButton.Number" android:text="4" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btn5" style="@style/CalculatorButton.Number" android:text="5" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btn6" style="@style/CalculatorButton.Number" android:text="6" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        
        <!-- Vertical spanning Plus -->
        <Button android:id="@+id/btnPlus" style="@style/CalculatorButton.Operator" android:text="+" 
            android:backgroundTint="@color/colorPrimary"
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"
            android:layout_rowSpan="2"/>

        <!-- Row 4 -->
        <Button android:id="@+id/btn1" style="@style/CalculatorButton.Number" android:text="1" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btn2" style="@style/CalculatorButton.Number" android:text="2" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btn3" style="@style/CalculatorButton.Number" android:text="3" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>

        <!-- Row 5 -->
        <Button android:id="@+id/btn0" style="@style/CalculatorButton.Number" android:text="0" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btnDecimal" style="@style/CalculatorButton" android:text="." 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"/>
        <Button android:id="@+id/btnPay" style="@style/CalculatorButton.Accent" android:text="TOTAL" 
            android:layout_columnWeight="1" android:layout_rowWeight="1" android:layout_gravity="fill"
            android:layout_columnSpan="2"/>

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
